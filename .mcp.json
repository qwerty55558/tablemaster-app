{
  "mcpServers": {
    "db-server": {
      "command": "sh",
      "args": ["-c", ". ./.env && npx -y @modelcontextprotocol/server-postgres postgresql://$DB_USER:$DB_PASSWORD@$DB_HOST:$DB_PORT/$DB_NAME"]
    },
    "browser": {
      "command": "npx",
      "args": ["-y", "agent-browser-mcp-native"]
    },
    "swagger": {
      "command": "npx",
      "args": ["-y", "api-mcp-server", "--doc-url", "http://127.0.0.1:8080/v3/api-docs"]
    }
  }
}